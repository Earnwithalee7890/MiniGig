  "repository": {
    "type": "git",
    "url": "git+https://github.com/Earnwithalee7890/MiniGig.git",
    "directory": "contracts-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
